EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@example.com
EMAIL_APP_PASSWORD=your_app_password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
REPORT_URL=http://127.0.0.1:8001/
REPORT_API_URL=http://127.0.0.1:8001/api/facts
PUBLIC_REPORT_URL_FILE=/Users/dave/Desktop/Cursor/data/public_report_url.txt
USE_DYNAMIC_PUBLIC_REPORT_URL=false
NEWS_BRAND=Big Daves News
ADMIN_TOKEN=change_this_to_a_private_admin_token
SCHEDULER_TIMEZONE=America/Chicago
DAILY_SEND_HOUR_LOCAL=8
DAILY_SEND_MINUTE_LOCAL=0
DAILY_SEND_WINDOW_MINUTES=180
FORCE_SEND_NOW=false
HEADLINES_PER_TOPIC_LIMIT=5
HEADLINES_TOTAL_LIMIT=40
HEADLINE_REFRESH_API_URL=http://127.0.0.1:8001/api/facts
FREE_LLM_BASE_URL=http://127.0.0.1:11434
FREE_LLM_MODEL=llama3.2:3b
HOSTED_LLM_BASE_URL=https://openrouter.ai/api/v1
HOSTED_LLM_MODEL=openai/gpt-4o-mini
HOSTED_LLM_API_KEY=
HOSTED_LLM_TIMEOUT_SECONDS=30
HOSTED_LLM_REFERER=
HOSTED_LLM_APP_NAME=Big Daves News
# APNs placeholder values for future server-side push delivery.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.bigdavesnews.app
APNS_PRIVATE_KEY=
APNS_ENV=production
PUSH_SEND_HOUR_LOCAL=8
PUSH_SEND_MINUTE_LOCAL=0
PUSH_SEND_WINDOW_MINUTES=180
FORCE_SEND_PUSH_NOW=false
PUSH_ALERT_TITLE=Big Daves News
PUSH_ALERT_BODY=Your daily brief is ready. Open the app for the latest headlines.
# Optional: when set, Postgres is used instead of local SQLite.
DATABASE_URL=
DATA_DB_PATH=data/big_daves_news.db

# Watch tab — TMDB v3 API (see https://www.themoviedb.org/settings/api)
# Copy this file to `.env` and paste your **API Key (v3)** here. The read access token is not used by this app.
TMDB_API_KEY=
# Optional region for watch provider metadata (default US).
TMDB_REGION=US
