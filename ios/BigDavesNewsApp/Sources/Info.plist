		<string>hbomax</string>
		<string>hmax</string>
		<string>disneyplus</string>
		<string>aiv</string>
		<string>amzn</string>
		<string>hulu</string>
		<string>com.apple.tv</string>
		<string>videos</string>
		<string>paramountplus</string>
		<string>cbs</string>
		<string>peacock</string>
	</array>
</dict>
</plist>
